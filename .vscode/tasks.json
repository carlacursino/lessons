{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "fpm-build-debug",
            "type": "shell",
            "command": "fpm build --profile debug && (cd build && ln -sf $(find . -type f -name lessons -printf '%T@ %p\\n' | sort -n | tail -1 | awk '{print $2}') debug_bin)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "fortran",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(.*):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        }
    ]
}